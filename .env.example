# Server
PORT=4000

# Option B: discrete MySQL connection settings (used when DATABASE_URL is empty)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=github_analyzer

# Set to "true" when connecting to a managed MySQL that requires SSL
# (e.g. Aiven, PlanetScale, some Railway setups).
DB_SSL=false

# Optional: a GitHub Personal Access Token (no scopes needed for public data).
# Without it the GitHub API allows 60 requests/hour; with it, 5000/hour.
GITHUB_TOKEN=
